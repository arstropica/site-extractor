# Site Extractor Docker Configuration

# Host port (UI + API served from single container)
DOCKER_PORT=12000

# Docker network name
DOCKER_NETWORK=extractor_network

# Host path for persistent data (scraped pages, downloaded resources, SQLite DB)
# Bind-mounted to /data inside each service container.
DATA_PATH=./data

# Redis
REDIS_URL=redis://redis:6379

# Max download size per job in bytes (default: 500MB)
MAX_DOWNLOAD_SIZE=524288000

# Encryption key for stored credentials (CHANGE IN PRODUCTION)
ENCRYPTION_KEY=change-me-in-production

# HTTP/HTTPS proxy (optional)
HTTP_PROXY=
HTTPS_PROXY=
